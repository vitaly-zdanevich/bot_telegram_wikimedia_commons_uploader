# Extra Debian packages baked into the Toolforge Build Service image.
# Cloud Native Buildpacks reads this file from the repo root. Debian main only (no non-free).

# Free RAR/zip extractor used by the `rar` Cargo feature.
unar

# LibRaw command-line decoder used as a DNG raw-development fallback.
libraw-bin

# External media links are resolved with yt-dlp; ffmpeg remuxes supported streams
# or converts unsupported audio/video to Commons-friendly OGG/Opus or WebM AV1/Opus.
yt-dlp
ffmpeg

# Used by the Toolforge wrapper to register the local Bot API webhook on startup.
curl

# Runtime shared libs for HEIC->WebP — uncomment only if you build with --features heic.
# libheif1
# libde265-0
